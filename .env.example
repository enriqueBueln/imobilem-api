# Copy this file to .env and fill in the real values. .env is gitignored.

# === App ===
APP_ENV=dev
# Set to true to log every SQL query (debugging only)
SQL_ECHO=false

# === Auth / JWT ===
# Generate a real secret with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-use-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# === CORS (Expo app origins, comma-separated) ===
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# === Database (local Postgres) ===
# Adjust user, password and database name to your local Postgres.
# Driver MUST be asyncpg (the +asyncpg part).
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/imobilem_dev

# === SAP (DEV) — from Federico's .docx. NEVER commit the real values. ===
SAP_BASE_URL=http://TLALOC.idei.com.mx:1080/sap/opu/odata/sap/ZBP_INB_TEST_SRV/
SAP_USER=COM_ENK_IMO
SAP_PASSWORD=
SAP_TIMEOUT_SECONDS=30
